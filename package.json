{
  "name": "crisis-desk-ai",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "node transaction-check.mjs && rimraf dist && tsc --noEmit && eslint 'src/**/*.ts' --max-warnings=0",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:check": "prettier --check --ignore-path .gitignore .",
    "prettier:fix": "prettier --write --ignore-path .gitignore .",
    "lint-prettier": "yarn lint:check && yarn prettier:check",
    "husky-install": "husky install",
    "husky-prepare-pre-commit": "husky add .husky/pre-commit 'yarn lint-staged'",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:create": "ts-node ./src/database/scripts/migration.create.ts",
    "migration:generate": "yarn migration:run && ts-node ./src/database/scripts/migration.generate.ts",
    "migration:run": "yarn typeorm migration:run -d ./src/database/data-source.ts",
    "migration:revert": "yarn typeorm migration:revert -d ./src/database/data-source.ts",
    "db:drop": "yarn typeorm schema:drop -d ./src/database/data-source.ts",
    "db:seed": "node dist/database/seeds/seed.js"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "yarn prettier:check",
      "yarn lint:check"
    ]
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@nestjs/cqrs": "11.0.3",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.24",
    "@nestjs/platform-socket.io": "11.1.24",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.1",
    "@nestjs/websockets": "11.1.24",
    "archiver": "8.0.0",
    "axios": "1.16.1",
    "bcryptjs": "3.0.3",
    "bullmq": "5.77.7",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cli-progress": "3.12.0",
    "csv-parser": "3.2.1",
    "dayjs": "1.11.21",
    "dotenv": "17.4.2",
    "firebase-admin": "13.10.0",
    "handlebars": "4.7.9",
    "helmet": "8.2.0",
    "husky": "9.1.7",
    "iovalkey": "0.3.3",
    "livekit-server-sdk": "2.15.4",
    "nest-winston": "1.10.2",
    "nestjs-cls": "6.2.1",
    "node-cache": "5.1.2",
    "nodemailer": "8.0.10",
    "otp-without-db": "1.0.6",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "8.21.0",
    "puppeteer": "25.1.0",
    "reflect-metadata": "0.2.2",
    "request-ip": "3.3.0",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "typeorm": "1.0.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/testing": "11.1.24",
    "@types/archiver": "7.0.0",
    "@types/express": "5.0.6",
    "@types/helmet": "4.0.0",
    "@types/jest": "29.5.14",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.1",
    "@types/nodemailer": "8.0.0",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/pg": "8.20.0",
    "@types/request-ip": "0.0.41",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-unused-imports": "4.4.1",
    "jest": "30.4.2",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.60.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
