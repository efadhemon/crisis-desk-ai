#-------------------------------------------------
#               Application
#-------------------------------------------------
PORT=$PORT
SECONDARY_PORT=$SECONDARY_PORT
NODE_ENV=$NODE_ENV
APP_NAME=$APP_NAME

API_PREFIX=api/v1
TZ=UTC
TIME_ZONE=Asia/Dhaka

#-------------------------------------------------
#                   Swagger
#-------------------------------------------------
API_VERSION=1.0.0
API_TITLE="Wagehat Core API - Staging"
API_DESCRIPTION="Wagehat Core API - Staging"


#-------------------------------------------------
#                   Default DB
#-------------------------------------------------
DB_TYPE=$DB_TYPE
DB_HOST=$DB_HOST
DB_PORT=$DB_PORT
DB_USERNAME=$DB_USERNAME
DB_PASSWORD=$DB_PASSWORD
DB_DATABASE=$DB_DATABASE
DB_LOGGING=$DB_LOGGING
DB_SSL_MODE=$DB_SSL_MODE
DB_REJECT_UNAUTHORIZED=$DB_REJECT_UNAUTHORIZED


#-------------------------------------------------
#                   Security
#-------------------------------------------------
CORS_ALLOWED_ORIGINS=$CORS_ALLOWED_ORIGINS
RATE_LIMIT_TTL=$RATE_LIMIT_TTL
RATE_LIMIT_MAX=$RATE_LIMIT_MAX


#-------------------------------------------------
#                  JWT
#-------------------------------------------------
JWT_SECRET=$JWT_SECRET
JWT_SALT_ROUNDS=$JWT_SALT_ROUNDS
JWT_EXPIRES_IN=$JWT_EXPIRES_IN
JWT_REFRESH_TOKEN_EXPIRES_IN=$JWT_REFRESH_TOKEN_EXPIRES_IN


#-------------------------------------------------
#                  S3 Storage
#-------------------------------------------------
S3_REGION=$S3_REGION
S3_ENDPOINT=$S3_ENDPOINT
S3_ACCESS_KEY=$S3_ACCESS_KEY
S3_SECRET_KEY=$S3_SECRET_KEY
S3_BUCKET=$S3_BUCKET
S3_CDN_URL=$S3_CDN_URL

# Temporary S3 Storage old for delete old data from space don't remove it without any discussion
S3_REGION_OLD=$S3_REGION_OLD
S3_ENDPOINT_OLD=$S3_ENDPOINT_OLD
S3_ACCESS_KEY_OLD=$S3_ACCESS_KEY_OLD
S3_SECRET_KEY_OLD=$S3_SECRET_KEY_OLD
S3_BUCKET_OLD=$S3_BUCKET_OLD


#-------------------------------------------------
#                  Valkey Queue
#-------------------------------------------------
QUEUE_HOST=$QUEUE_HOST
QUEUE_PORT=$QUEUE_PORT
QUEUE_PASSWORD=$QUEUE_PASSWORD
QUEUE_USERNAME=$QUEUE_USERNAME

#-------------------------------------------------
#                  Valkey Cache
#-------------------------------------------------
CACHE_STORE_HOST=$CACHE_STORE_HOST
CACHE_STORE_PORT=$CACHE_STORE_PORT
CACHE_STORE_PASSWORD=$CACHE_STORE_PASSWORD
CACHE_STORE_USERNAME=$CACHE_STORE_USERNAME
CACHE_TTL=$CACHE_TTL


#-------------------------------------------------
#               Seed Data
#-------------------------------------------------
SUPER_ADMIN_EMAIL=$SUPER_ADMIN_EMAIL
SUPER_ADMIN_PASSWORD=$SUPER_ADMIN_PASSWORD


#-------------------------------------------------
#               Firebase
#-------------------------------------------------
FIREBASE_PROJECT_ID=$FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=$FIREBASE_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY_BASE64=$FIREBASE_PRIVATE_KEY_BASE64


#-------------------------------------------------
#               Google Auth
#-------------------------------------------------
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_SECRET=$GOOGLE_SECRET
GOOGLE_REDIRECT_URL=$GOOGLE_REDIRECT_URL


#-------------------------------------------------
#               Facebook Auth
#-------------------------------------------------
FB_API_VERSION=$FB_API_VERSION
FACEBOOK_CLIENT_ID=$FACEBOOK_CLIENT_ID
FACEBOOK_SECRET=$FACEBOOK_SECRET
FACEBOOK_REDIRECT_URL=$FACEBOOK_REDIRECT_URL
FACEBOOK_CONFIG_ID=$FACEBOOK_CONFIG_ID


#-------------------------------------------------
#               Telegram
#-------------------------------------------------
# Telegram token and chat ID for general notifications
TELEGRAM_TOKEN=$TELEGRAM_TOKEN
TELEGRAM_CHAT_ID=$TELEGRAM_CHAT_ID

# Telegram token and chat ID for technical notifications
TELEGRAM_TOKEN_FOR_TECH=$TELEGRAM_TOKEN_FOR_TECH
TELEGRAM_CHAT_ID_FOR_TECH=$TELEGRAM_CHAT_ID_FOR_TECH


#-------------------------------------------------
#               Authenticator
#-------------------------------------------------
GOOGLE_AUTHENTICATOR_ISSUER=$GOOGLE_AUTHENTICATOR_ISSUER


#-------------------------------------------------
#           Payment Gateway SSL_COMMERZ
#-------------------------------------------------
SSL_COMMERZ_STORE_ID=$SSL_COMMERZ_STORE_ID
SSL_COMMERZ_STORE_PASSWORD=$SSL_COMMERZ_STORE_PASSWORD
SSL_COMMERZ_PAYMENT_URL=$SSL_COMMERZ_PAYMENT_URL
SSL_COMMERZ_PAYMENT_VALIDATION_URL=$SSL_COMMERZ_PAYMENT_VALIDATION_URL
SSL_COMMERZ_SUCCESS_URL=$SSL_COMMERZ_SUCCESS_URL
SSL_COMMERZ_FAILED_URL=$SSL_COMMERZ_FAILED_URL
SSL_COMMERZ_CANCELED_URL=$SSL_COMMERZ_CANCELED_URL
SSL_COMMERZ_IPN_URL=$SSL_COMMERZ_IPN_URL


#-------------------------------------------------
#          External APIS
#-------------------------------------------------
WAGE_CORE_API_ENDPOINT=$WAGE_CORE_API_ENDPOINT


#-------------------------------------------------
#          Public API Keys
#-------------------------------------------------
VIDEO_PROGRESS_KEY=$VIDEO_PROGRESS_KEY
APP_SCREEN_SYNC_KEY=$APP_SCREEN_SYNC_KEY


#-------------------------------------------------
#          Observability (Grafana Cloud)
#-------------------------------------------------
# Winston logs folder
LOG_FOLDER=logs

# Write logs to stdout (for `docker logs`). Adds I/O alongside file transports when true.
LOG_TO_CONSOLE=true

# This for enable observability tracing - true/false
OBSERVABILITY_ENABLED=$OBSERVABILITY_ENABLED

# Grafana Cloud OTLP Endpoint (get from Grafana Cloud → My Account → OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=$OTEL_EXPORTER_OTLP_ENDPOINT

# Base64 of <instance-id>:<cloud-api-token> → echo -n "instance:token" | base64
OTEL_EXPORTER_OTLP_HEADERS=$OTEL_EXPORTER_OTLP_HEADERS



#-------------------------------------------------
#          Suppotot Module (Livekit)
#-------------------------------------------------
LIVEKIT_API_KEY=$LIVEKIT_API_KEY
LIVEKIT_API_SECRET=$LIVEKIT_API_SECRET
LIVEKIT_URL=$LIVEKIT_URL
