#-------------------------------------------------
#               Application
#-------------------------------------------------
PORT=$PORT
NODE_ENV=$NODE_ENV
APP_NAME=$APP_NAME

API_PREFIX=api
API_VERSION=1.0.0
API_TITLE="CrisisDesk AI API"
API_DESCRIPTION="CrisisDesk AI API"

#-------------------------------------------------
#          CrisisDesk AI - Gemini
#-------------------------------------------------
GEMINI_API_KEY=$GEMINI_API_KEY
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

#-------------------------------------------------
#          CrisisDesk AI - Duplicate detection
#-------------------------------------------------
DUPLICATE_SIMILARITY_THRESHOLD=0.85

#-------------------------------------------------
#          CrisisDesk AI - Admin auth
#-------------------------------------------------
# AUTH_ENABLED=false keeps admin endpoints open (recommended for automated graders).
AUTH_ENABLED=false
ADMIN_EMAIL=$ADMIN_EMAIL
ADMIN_PASSWORD=$ADMIN_PASSWORD

#-------------------------------------------------
#                   Default DB
#-------------------------------------------------
DB_TYPE=$DB_TYPE
DB_HOST=$DB_HOST
DB_PORT=$DB_PORT
DB_USERNAME=$DB_USERNAME
DB_PASSWORD=$DB_PASSWORD
DB_DATABASE=$DB_DATABASE
DB_LOGGING=$DB_LOGGING
DB_SSL_MODE=$DB_SSL_MODE
DB_REJECT_UNAUTHORIZED=$DB_REJECT_UNAUTHORIZED
# DB_CERT_BASE64=$DB_CERT_BASE64

#-------------------------------------------------
#                   Security
#-------------------------------------------------
CORS_ALLOWED_ORIGINS=$CORS_ALLOWED_ORIGINS
RATE_LIMIT_TTL=$RATE_LIMIT_TTL
RATE_LIMIT_MAX=$RATE_LIMIT_MAX
# SKIP_SECURITY=false

#-------------------------------------------------
#                  JWT
#-------------------------------------------------
JWT_SECRET=$JWT_SECRET
JWT_SALT_ROUNDS=$JWT_SALT_ROUNDS
JWT_EXPIRES_IN=$JWT_EXPIRES_IN
JWT_REFRESH_TOKEN_EXPIRES_IN=$JWT_REFRESH_TOKEN_EXPIRES_IN

#-------------------------------------------------
#                  S3 Storage
#-------------------------------------------------
S3_REGION=$S3_REGION
S3_ENDPOINT=$S3_ENDPOINT
S3_ACCESS_KEY=$S3_ACCESS_KEY
S3_SECRET_KEY=$S3_SECRET_KEY
S3_BUCKET=$S3_BUCKET
S3_CDN_URL=$S3_CDN_URL
# S3_ROOT_FOLDER=$S3_ROOT_FOLDER

# Temporary S3 Storage old for delete old data from space don't remove it without any discussion
S3_REGION_OLD=$S3_REGION_OLD
S3_ENDPOINT_OLD=$S3_ENDPOINT_OLD
S3_ACCESS_KEY_OLD=$S3_ACCESS_KEY_OLD
S3_SECRET_KEY_OLD=$S3_SECRET_KEY_OLD
S3_BUCKET_OLD=$S3_BUCKET_OLD

#-------------------------------------------------
#                  Valkey Queue
#-------------------------------------------------
QUEUE_HOST=$QUEUE_HOST
QUEUE_PORT=$QUEUE_PORT
QUEUE_PASSWORD=$QUEUE_PASSWORD
QUEUE_USERNAME=$QUEUE_USERNAME

#-------------------------------------------------
#                  Valkey Cache
#-------------------------------------------------
CACHE_STORE_HOST=$CACHE_STORE_HOST
CACHE_STORE_PORT=$CACHE_STORE_PORT
CACHE_STORE_PASSWORD=$CACHE_STORE_PASSWORD
CACHE_STORE_USERNAME=$CACHE_STORE_USERNAME
CACHE_TTL=$CACHE_TTL

#-------------------------------------------------
#               Seed Data
#-------------------------------------------------
SUPER_ADMIN_EMAIL=$SUPER_ADMIN_EMAIL
SUPER_ADMIN_PASSWORD=$SUPER_ADMIN_PASSWORD

#-------------------------------------------------
#               Google Auth
#-------------------------------------------------
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_SECRET=$GOOGLE_SECRET
GOOGLE_REDIRECT_URL=$GOOGLE_REDIRECT_URL

#-------------------------------------------------
#               Facebook Auth
#-------------------------------------------------
FB_API_VERSION=$FB_API_VERSION
FACEBOOK_CLIENT_ID=$FACEBOOK_CLIENT_ID
FACEBOOK_SECRET=$FACEBOOK_SECRET
FACEBOOK_REDIRECT_URL=$FACEBOOK_REDIRECT_URL
FACEBOOK_CONFIG_ID=$FACEBOOK_CONFIG_ID

#-------------------------------------------------
#               Authenticator
#-------------------------------------------------
GOOGLE_AUTHENTICATOR_ISSUER=$GOOGLE_AUTHENTICATOR_ISSUER

#-------------------------------------------------
#          Observability (Grafana Cloud)
#-------------------------------------------------
LOG_FOLDER=logs
LOG_TO_CONSOLE=true
OBSERVABILITY_ENABLED=$OBSERVABILITY_ENABLED
OTEL_EXPORTER_OTLP_ENDPOINT=$OTEL_EXPORTER_OTLP_ENDPOINT
OTEL_EXPORTER_OTLP_HEADERS=$OTEL_EXPORTER_OTLP_HEADERS

#-------------------------------------------------
#               Development toggles
#-------------------------------------------------
# SKIP_AUTH=false
# EXPORT_OPENAPI_JSON=false
